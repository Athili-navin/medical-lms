# Required — real authentication & database (no demo mode)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: service role — required for note images in production (signed URLs)
# Supabase → Project Settings → API → service_role key (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (INR — ₹2,000/year subscription)
# 1. Sign up at https://dashboard.razorpay.com
# 2. Settings → API Keys → Generate Test Keys (for development)
# 3. For live site: switch to Live Mode and use live keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key

# Razorpay setup checklist:
# - Do NOT set NEXT_PUBLIC_RAZORPAY_KEY_ID (Key ID is returned from /api/payments/create-order)
# - Test payment: use card 4111 1111 1111 1111, any future expiry, any CVV
# - Netlify Production: RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET only (remove NEXT_PUBLIC_RAZORPAY_KEY_ID if set)
# - Supabase redirect URLs must include your live domain

# Setup steps:
# 1. Create a Supabase project at https://supabase.com
# 2. Copy URL + anon key above into .env.local
# 3. Run supabase/schema.sql in Supabase SQL Editor
# 4. Supabase → Authentication → URL Configuration:
#    Site URL: http://localhost:3000  (or your Netlify URL in production)
#    Redirect URLs:
#      http://localhost:3000/auth/callback
#      http://localhost:3000/reset-password
#      https://YOUR-SITE.netlify.app/auth/callback
#      https://YOUR-SITE.netlify.app/reset-password
# 5. Create users via /signup or Authentication → Users
# 6. Set tutor role: UPDATE profiles SET role = 'tutor' WHERE email = 'your@email.com';
# 7. Demo student (testing, no subscription): see supabase/make-demo-student.sql
#
# Video storage (Supabase Dashboard → Storage):
# - Bucket: lecture-videos (private) — created by supabase/schema.sql
# - Tutor upload: /tutor/videos → Choose file (uploads to lecture-videos/chapters/{chapterId}/...)
# - Or manual upload in Storage, then paste path in Video URL field
# - YouTube links do NOT work — use MP4/WebM files only
#
# Personal notes:
# - Saved automatically via /api/notes → personal_notes table in Supabase
# - Students must be logged in; each user sees only their own notes
#
# Video DRM (not free for production):
# - True DRM = Widevine (Chrome/Android) + FairPlay (Safari/iOS) via a licensed host
# - Free tools only: FFmpeg + Shaka Packager (encrypt) + Shaka Player (play) — still need a license server
# - Cheapest paid paths: Cloudflare Stream, Mux, Bitmovin (compare pricing for your volume)
# - Current app: private Supabase bucket + short-lived signed URLs (soft protection, not DRM)
